---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AirFreightPage from '../../components/react/AirFreightPage';
import { pageMeta } from '../../lib/page-meta';
import { airFreightServiceFaqs, airFreightServiceSchema, faqPageSchema, jsonLdScript } from '../../lib/json-ld';

const meta = pageMeta({
  title: 'Pharmaceutical Air Freight from Thailand',
  description:
    'GDP-certified pharmaceutical air freight from Bangkok — cold chain awareness, compliance documentation, and transparent chargeable weight pricing.',
  path: '/services/air-freight',
});

const faqLd = faqPageSchema(airFreightServiceFaqs);
const ld = jsonLdScript([
  airFreightServiceSchema(),
  ...(faqLd ? [faqLd] : []),
]);
---

<BaseLayout meta={meta} jsonLd={ld}>
  <AirFreightPage client:load />
</BaseLayout>
