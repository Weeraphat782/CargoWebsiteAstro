---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MarketingPageHero from '../../components/MarketingPageHero.astro';
import { services } from '../../data/marketing-services';
import { pageMeta } from '../../lib/page-meta';
import { absoluteUrl, BRAND_NAME } from '../../lib/site';
import { itemListSchema, jsonLdScript, webPageSchema } from '../../lib/json-ld';

const meta = pageMeta({
  title: 'Services',
  description:
    'Specialized air freight, shipping & customs, GDP warehousing, and controlled temperature transport—end-to-end logistics from OMG Experience.',
  path: '/services',
});

const listItems = services.map((s) => ({
  name: s.title,
  url: absoluteUrl(`/services#${s.id}`),
}));

const ld = jsonLdScript([
  webPageSchema({
    path: '/services',
    name: `${BRAND_NAME} services overview`,
    description: 'Air freight, customs and documents, GDP warehousing, and cold-chain transport.',
  }),
  itemListSchema(`${BRAND_NAME} service lines`, listItems),
]);
---

<BaseLayout meta={meta} jsonLd={ld}>
  <MarketingPageHero
    eyebrow="Services"
    title="Our Services"
    description="End-to-end logistics for specialized air freight, customs clearance, pharmaceutical-grade warehousing, controlled temperature transport and QC lab testing."
  />
  <div class="marketing-container pb-[72px] pt-4">
    {
      services.map((s, i) => {
        const flip = i % 2 === 1;
        return (
          <article
            id={s.id}
            class:list={[
              'grid scroll-mt-28 items-center gap-11 border-b border-[#eef1f4] py-12 lg:grid-cols-2',
            ]}
          >
            <div class:list={[flip && 'lg:order-2']}>
              <span class="text-eyebrow mb-3.5 inline-block" style="color: var(--green-500);">
                Service
              </span>
              <h2 class="font-display text-[30px] font-bold" style="color: var(--navy-950);">
                {s.title}
              </h2>
              <p class="mt-2 text-[15px] font-semibold" style="color: var(--navy-500);">
                {s.shortDescription}
              </p>
              <p class="mt-3.5 text-[15px] leading-relaxed" style="color: #444c54;">
                {s.fullDescription}
              </p>
              <a
                href="/contact"
                class="mt-6 inline-flex items-center gap-2 rounded-[var(--radius-sm)] px-5 py-2.5 text-[14.5px] font-semibold text-white"
                style="background: var(--navy-700);"
              >
                Request a quote →
              </a>
            </div>
            <div class:list={['overflow-hidden rounded-[var(--radius-lg)] border border-[var(--line)] aspect-[4/3]', flip && 'lg:order-1']}>
              <img src={s.imageUrl} alt={s.title} class="h-full w-full object-cover" loading="lazy" />
            </div>
          </article>
        );
      })
    }
    <div class="mt-10 rounded-[var(--radius-lg)] border border-[var(--line)] bg-[var(--paper-muted)] p-9 text-center">
      <h3 class="font-display text-2xl font-bold" style="color: var(--navy-950);">
        Ready to move your cargo?
      </h3>
      <p class="mt-2 text-[15px]" style="color: var(--muted);">
        Tell us about your shipment and our team will respond within one business day.
      </p>
      <a
        href="/contact"
        class="mt-5 inline-flex rounded-[var(--radius-sm)] px-7 py-3 text-[15px] font-semibold text-white"
        style="background: var(--green-500);"
      >
        Request a Quote
      </a>
    </div>
  </div>
</BaseLayout>
