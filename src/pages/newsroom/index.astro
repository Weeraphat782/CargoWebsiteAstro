---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsCard from '../../components/NewsCard.astro';
import NewsroomPagination from '../../components/NewsroomPagination.astro';
import MarketingPageHero from '../../components/MarketingPageHero.astro';
import ContinueExploring from '../../components/ContinueExploring.astro';
import {
  getPublishedArticlesList,
  mapNewsroomListArticles,
  NEWSROOM_PAGE_SIZE,
  newsroomListPagePath,
  newsroomListTotalPages,
} from '../../lib/newsroom-data';
import { pageMeta } from '../../lib/page-meta';
import { absoluteUrl, BRAND_NAME } from '../../lib/site';
import { itemListSchema, jsonLdScript, webPageSchema } from '../../lib/json-ld';
import { marketingHeroImages } from '../../data/marketing-hero-images';

const currentPage = 1;
const rows = await getPublishedArticlesList();
const allArticles = mapNewsroomListArticles(rows);
const totalPages = newsroomListTotalPages(allArticles.length);
const pageArticles = allArticles.slice(0, NEWSROOM_PAGE_SIZE);
const [featured, ...restArticles] = pageArticles;

const meta = pageMeta({
  title: 'Newsroom',
  description:
    'Company announcements, route updates, and logistics industry news from OMG Experience.',
  path: '/newsroom',
});

const listItems = pageArticles.map((a) => ({
  name: a.title,
  url: absoluteUrl(`/newsroom/${a.slug}`),
}));

const ld = jsonLdScript([
  webPageSchema({
    path: '/newsroom',
    name: `${BRAND_NAME} Newsroom`,
    description: 'Updates on logistics operations, industry context, and company announcements.',
  }),
  ...(listItems.length ? [itemListSchema(`${BRAND_NAME} news articles`, listItems)] : []),
]);

const nextUrl = totalPages > 1 ? absoluteUrl(newsroomListPagePath(2)) : undefined;
---

<BaseLayout meta={meta} jsonLd={ld} nextUrl={nextUrl}>
  <MarketingPageHero
    eyebrow="Newsroom"
    title="Newsroom"
    description="Company announcements, route updates and logistics industry news."
    backgroundImage={marketingHeroImages.newsroom.src}
    backgroundImageAlt={marketingHeroImages.newsroom.alt}
  />
  <div class="marketing-container py-12 pb-[72px]">
    {
      pageArticles.length === 0 ? (
        <p class="py-8 text-center" style="color: #9aa2aa;">No articles published yet.</p>
      ) : (
        <>
          {featured && (
            <NewsCard
              slug={featured.slug}
              title={featured.title}
              date={featured.date}
              excerpt={featured.excerpt}
              imageUrl={featured.imageUrl}
              featured
            />
          )}
          <div class="mt-9 grid gap-[22px] sm:grid-cols-2 lg:grid-cols-3">
            {restArticles.map((item) => (
              <NewsCard
                slug={item.slug}
                title={item.title}
                date={item.date}
                excerpt={item.excerpt}
                imageUrl={item.imageUrl}
              />
            ))}
          </div>
        </>
      )
    }
    <NewsroomPagination currentPage={currentPage} totalPages={totalPages} />
    <ContinueExploring />
  </div>
</BaseLayout>
