---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import NewsCard from '../../../components/NewsCard.astro';
import NewsroomPagination from '../../../components/NewsroomPagination.astro';
import MarketingPageHero from '../../../components/MarketingPageHero.astro';
import { ContinueExploring } from '../../../components/react/ContinueExploring';
import {
  getPublishedArticlesList,
  mapNewsroomListArticles,
  NEWSROOM_PAGE_SIZE,
  newsroomListPagePath,
  newsroomListTotalPages,
  type NewsroomListArticle,
} from '../../../lib/newsroom-data';
import { pageMeta } from '../../../lib/page-meta';
import { absoluteUrl, BRAND_NAME } from '../../../lib/site';
import { itemListSchema, jsonLdScript, webPageSchema } from '../../../lib/json-ld';

export async function getStaticPaths() {
  const rows = await getPublishedArticlesList();
  const allArticles = mapNewsroomListArticles(rows);
  const totalPages = newsroomListTotalPages(allArticles.length);
  if (totalPages < 2) return [];

  return Array.from({ length: totalPages - 1 }, (_, i) => {
    const pageNum = i + 2;
    const start = (pageNum - 1) * NEWSROOM_PAGE_SIZE;
    const pageArticles = allArticles.slice(start, start + NEWSROOM_PAGE_SIZE);
    return {
      params: { page: String(pageNum) },
      props: { pageArticles, pageNum, totalPages },
    };
  });
}

interface Props {
  pageArticles: NewsroomListArticle[];
  pageNum: number;
  totalPages: number;
}

const { pageArticles, pageNum, totalPages } = Astro.props;

const meta = pageMeta({
  title: `Newsroom — Page ${pageNum}`,
  description:
    'Company announcements, route updates, and logistics industry news from OMG Experience.',
  path: newsroomListPagePath(pageNum),
});

const listItems = pageArticles.map((a) => ({
  name: a.title,
  url: absoluteUrl(`/newsroom/${a.slug}`),
}));

const ld = jsonLdScript([
  webPageSchema({
    path: newsroomListPagePath(pageNum),
    name: `${BRAND_NAME} Newsroom — Page ${pageNum}`,
    description: 'Updates on logistics operations, industry context, and company announcements.',
  }),
  ...(listItems.length ? [itemListSchema(`${BRAND_NAME} news articles`, listItems)] : []),
]);

const prevUrl = absoluteUrl(newsroomListPagePath(pageNum - 1));
const nextUrl =
  pageNum < totalPages ? absoluteUrl(newsroomListPagePath(pageNum + 1)) : undefined;
---

<BaseLayout meta={meta} jsonLd={ld} prevUrl={prevUrl} nextUrl={nextUrl}>
  <MarketingPageHero
    eyebrow="Newsroom"
    title={`Newsroom — Page ${pageNum}`}
    description="Company announcements, route updates and logistics industry news."
  />
  <div class="marketing-container py-12 pb-[72px]">
    <div class="grid gap-[22px] sm:grid-cols-2 lg:grid-cols-3">
      {pageArticles.map((item) => (
        <NewsCard
          slug={item.slug}
          title={item.title}
          date={item.date}
          excerpt={item.excerpt}
          imageUrl={item.imageUrl}
        />
      ))}
    </div>
    <NewsroomPagination currentPage={pageNum} totalPages={totalPages} />
    <ContinueExploring client:visible />
  </div>
</BaseLayout>
