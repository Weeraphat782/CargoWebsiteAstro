---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/react/ContactForm';
import { pageMeta } from '../lib/page-meta';
import { breadcrumbListSchema, jsonLdScript, webPageSchema } from '../lib/json-ld';
import { BRAND_NAME } from '../lib/site';

const meta = pageMeta({
  title: 'Contact Us',
  description:
    'Request a quote for air freight, customs clearance, warehousing, or controlled temperature transport. The OMG Experience team responds within one business day.',
  path: '/contact',
});

const ld = jsonLdScript([
  webPageSchema({
    path: '/contact',
    name: `Contact ${BRAND_NAME}`,
    description: 'Request quotes and speak with the logistics team about air freight, customs, GDP warehousing, and cold chain.',
  }),
]);

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  ...breadcrumbListSchema([
    { name: 'Home', path: '/' },
    { name: 'Contact', path: '/contact' },
  ]),
});
---

<BaseLayout meta={meta} jsonLd={ld} breadcrumbLd={breadcrumbLd}>
  <div class="bg-neutral-50 min-h-screen">
    <div class="border-b border-neutral-200 bg-white px-4 py-10 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="accent-bar mb-4"></div>
        <h1 class="text-3xl font-bold text-neutral-900 sm:text-4xl">Contact Us</h1>
        <p class="mt-3 max-w-xl text-neutral-500">
          Request a quote for air freight, customs clearance, warehousing, or cold chain transport.
        </p>
      </div>
    </div>
    <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
      <div class="grid gap-8 lg:grid-cols-3 lg:gap-12">
        <aside class="lg:col-span-1">
          <div class="rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm">
            <h2 class="mb-4 text-sm font-bold uppercase tracking-widest text-neutral-400">Get in touch</h2>
            <p class="text-sm text-neutral-600">Email: <a href="mailto:info@omgexp.com" class="font-medium" style="color: var(--color-primary-ref)">info@omgexp.com</a></p>
            <p class="mt-2 text-sm text-neutral-600">Location: Bangkok, Thailand</p>
            <p class="mt-2 text-sm text-neutral-600">Response: Within 1 business day</p>
          </div>
        </aside>
        <div class="lg:col-span-2">
          <div class="rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm sm:p-8">
            <h2 class="mb-6 text-lg font-bold text-neutral-900">Send us a message</h2>
            <ContactForm client:load />
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
