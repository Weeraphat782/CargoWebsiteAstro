---
import BaseLayout from '../layouts/BaseLayout.astro';
import MarketingPageHero from '../components/MarketingPageHero.astro';
import MarketingIcon from '../components/MarketingIcon.astro';
import ContactForm from '../components/react/ContactForm';
import { pageMeta } from '../lib/page-meta';
import { breadcrumbListSchema, jsonLdScript, webPageSchema } from '../lib/json-ld';
import { APP_URL, BRAND_NAME } from '../lib/site';
import { marketingHeroImages } from '../data/marketing-hero-images';

const meta = pageMeta({
  title: 'Contact Us',
  description:
    'Request a quote for air freight, customs clearance, warehousing, or controlled temperature transport. The OMG Experience team responds within one business day.',
  path: '/contact',
});

const ld = jsonLdScript([
  webPageSchema({
    path: '/contact',
    name: `Contact ${BRAND_NAME}`,
    description: 'Request quotes and speak with the logistics team about air freight, customs, GDP warehousing, and cold chain.',
  }),
]);

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  ...breadcrumbListSchema([
    { name: 'Home', path: '/' },
    { name: 'Contact', path: '/contact' },
  ]),
});

const loginUrl = `${APP_URL}/site/login`;
---

<BaseLayout meta={meta} jsonLd={ld} breadcrumbLd={breadcrumbLd}>
  <Fragment slot="head">
    <link rel="preload" as="image" href={marketingHeroImages.contact.src} />
  </Fragment>
  <MarketingPageHero
    eyebrow="Contact Us"
    title="Contact Us"
    description="Request a quote for air freight, customs clearance, warehousing or cold-chain transport."
    backgroundImage={marketingHeroImages.contact.src}
    backgroundImageAlt={marketingHeroImages.contact.alt}
    priority
  />
  <div class="marketing-container grid gap-12 py-14 pb-[72px] lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
    <div>
      <h2 class="font-display mb-5 text-2xl font-bold" style="color: var(--navy-950);">Get in touch</h2>
      <div class="flex flex-col gap-[18px] text-[15px]">
        <div class="flex gap-3.5">
          <span
            class="flex h-[42px] w-[42px] shrink-0 items-center justify-center rounded-[3px]"
            style="background: #e6eef6; color: var(--navy-700);"
          >
            <MarketingIcon name="mail" />
          </span>
          <div>
            <div class="text-[12px] font-bold uppercase tracking-[0.06em]" style="color: #9aa2aa;">Email</div>
            <a href="mailto:cargo@omgexp.com" class="font-semibold" style="color: var(--navy-700);">
              cargo@omgexp.com
            </a>
          </div>
        </div>
        <div class="flex gap-3.5">
          <span
            class="flex h-[42px] w-[42px] shrink-0 items-center justify-center rounded-[3px]"
            style="background: #e6eef6; color: var(--navy-700);"
          >
            <MarketingIcon name="pin" />
          </span>
          <div>
            <div class="text-[12px] font-bold uppercase tracking-[0.06em]" style="color: #9aa2aa;">Location</div>
            <div class="font-semibold text-[var(--ink)]">Bangkok, Thailand</div>
          </div>
        </div>
        <div class="flex gap-3.5">
          <span
            class="flex h-[42px] w-[42px] shrink-0 items-center justify-center rounded-[3px]"
            style="background: #eaf6e0; color: #4a9c2d;"
          >
            <MarketingIcon name="clock" />
          </span>
          <div>
            <div class="text-[12px] font-bold uppercase tracking-[0.06em]" style="color: #9aa2aa;">Response</div>
            <div class="font-semibold text-[var(--ink)]">Within 1 business day</div>
          </div>
        </div>
      </div>
      <div class="mt-7 rounded-[var(--radius-md)] border border-[var(--line)] bg-[var(--paper-muted)] p-5">
        <div class="font-display font-bold" style="color: var(--navy-950);">Already a customer?</div>
        <p class="mt-1.5 text-[13.5px] leading-relaxed" style="color: var(--muted);">
          Track shipments and manage bookings in the Export Portal.
        </p>
        <a href={loginUrl} class="mt-3 inline-block text-sm font-semibold" style="color: var(--navy-700);">
          Go to Export Portal →
        </a>
      </div>
    </div>
    <div class="rounded-[var(--radius-lg)] border border-[var(--line)] bg-white p-8 shadow-[0_8px_24px_rgba(13,44,77,0.06)]">
      <h2 class="font-display mb-5 text-[22px] font-bold" style="color: var(--navy-950);">Send us a message</h2>
      <ContactForm client:load />
    </div>
  </div>
</BaseLayout>
