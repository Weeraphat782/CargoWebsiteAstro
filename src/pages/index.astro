---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeHero from '../components/HomeHero.astro';
import MarketingHomePage from '../components/react/MarketingHomePage';
import { getCarrierBoardDisplayItems } from '../lib/carrier-board-data';
import { pageMeta } from '../lib/page-meta';
import { jsonLdScript, webPageSchema } from '../lib/json-ld';
import { BRAND_NAME } from '../lib/site';
import {
  getHeroBgMode,
  HERO_FALLBACK_IMAGE,
  HERO_POSTER_SRC,
  HERO_VIDEO_SRC,
} from '../lib/hero';

const meta = pageMeta({
  title: 'Air Freight & Pharmaceutical Logistics from Thailand',
  description:
    'End-to-end air freight from Bangkok and Thailand — GDP warehousing, customs clearance, and AI-assisted document intelligence for pharmaceutical and time-sensitive cargo.',
  path: '/',
});

const carrierItems = await getCarrierBoardDisplayItems();
const heroMode = getHeroBgMode();

const ld = jsonLdScript([
  webPageSchema({
    path: '/',
    name: `${BRAND_NAME} — Air Freight from Thailand`,
    description:
      'Specialized air freight from Bangkok and Thailand — GDP warehousing, customs, and cold-chain logistics with AI document verification.',
  }),
]);
---

<BaseLayout meta={meta} jsonLd={ld} showBreadcrumbNav={false}>
  <Fragment slot="head">
    {
      heroMode === 'video' ? (
        <>
          <link rel="preload" href={HERO_VIDEO_SRC} as="video" type="video/mp4" />
          <link rel="preload" href={HERO_POSTER_SRC} as="image" />
        </>
      ) : (
        <link rel="preload" href={HERO_FALLBACK_IMAGE} as="image" />
      )
    }
  </Fragment>
  <HomeHero carrierItems={carrierItems} />
  <MarketingHomePage client:visible />
</BaseLayout>
