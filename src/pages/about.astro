---
import BaseLayout from '../layouts/BaseLayout.astro';
import { pageMeta } from '../lib/page-meta';
import { breadcrumbListSchema, jsonLdScript, webPageSchema } from '../lib/json-ld';
import { BRAND_NAME } from '../lib/site';

const meta = pageMeta({
  title: 'About Us',
  description:
    'From GSA and airline distribution heritage to specialized pharmaceutical-grade logistics—industry expertise and routing intelligence at OMG Experience.',
  path: '/about',
});

const ld = jsonLdScript([
  webPageSchema({
    path: '/about',
    name: `About ${BRAND_NAME}`,
    description: 'Heritage in airline distribution and GSA, now focused on pharmaceutical-grade logistics.',
  }),
]);

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  ...breadcrumbListSchema([
    { name: 'Home', path: '/' },
    { name: 'About', path: '/about' },
  ]),
});

const stats = [
  { n: '7+', l: 'Countries served' },
  { n: 'GDP', l: 'Certified handling' },
  { n: 'AI', l: 'Document intelligence' },
  { n: '24h', l: 'Quote response' },
];

const values = [
  {
    title: 'Professionalism & reliability',
    desc: 'Consistent, dependable service backed by airline-grade operational discipline.',
    icon: 'check',
  },
  {
    title: 'Compliance & transparency',
    desc: 'Regulatory rigor and documented handling at every step of the journey.',
    icon: 'shield',
  },
  {
    title: 'Technology-driven traceability',
    desc: 'AI document intelligence and QR-tracked visibility from origin to delivery.',
    icon: 'lines',
  },
  {
    title: 'Customer-focused service',
    desc: 'Responsive teams that respond within one business day, every time.',
    icon: 'people',
  },
];

const teamPhoto =
  'https://images.unsplash.com/photo-1713947507314-4b71ea085d31?auto=format&fit=crop&w=800&q=72';
---

<BaseLayout meta={meta} jsonLd={ld} breadcrumbLd={breadcrumbLd}>
  <section class="relative overflow-hidden text-white" style="background: var(--navy-950);">
    <img
      src="https://images.unsplash.com/photo-1604140969696-0c495a16f300?auto=format&fit=crop&w=1800&q=72"
      alt="Cargo aircraft"
      class="absolute inset-0 h-full w-full object-cover opacity-50"
      loading="eager"
    />
    <div
      class="absolute inset-0"
      style="background: linear-gradient(110deg,rgba(13,44,77,.72),rgba(13,44,77,.48));"
    />
    <div class="marketing-container relative py-16">
      <div class="text-eyebrow mb-2.5">About Us</div>
      <h1 class="font-display max-w-[760px] text-[clamp(34px,4.5vw,52px)] font-extrabold leading-[1.05]">
        From airline distribution to specialized logistics
      </h1>
    </div>
  </section>

  <div class="marketing-container py-16">
    <div class="mb-16 grid items-center gap-14 lg:grid-cols-[1.15fr_1fr]">
      <div>
        <div class="accent-bar mb-5"></div>
        <p class="text-[17px] leading-relaxed" style="color: #2b3138;">
          OMG Experience has built its expertise on a foundation of traditional airline distribution and GSA
          heritage, transitioning into specialized pharmaceutical-grade logistics with modern traceability and
          compliance tooling.
        </p>
        <p class="mt-4 text-[15px] leading-relaxed" style="color: var(--muted);">
          Our airline heritage provides direct access to routing intelligence, capacity availability and optimal
          transit times across major global hubs — now paired with AI-powered document intelligence and validated
          cold-chain handling for the most demanding, regulated cargo.
        </p>
      </div>
      <div class="aspect-[4/3] overflow-hidden rounded-[var(--radius-lg)] border border-[var(--line)]">
        <img src={teamPhoto} alt="OMGEXP Bangkok team" class="h-full w-full object-cover" loading="lazy" />
      </div>
    </div>

    <div class="mb-16 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {
        stats.map((st) => (
          <div class="rounded-[var(--radius-md)] border border-[var(--line)] bg-[var(--paper-muted)] p-6 text-center">
            <div class="font-display text-[38px] font-extrabold" style="color: var(--navy-700);">
              {st.n}
            </div>
            <div class="mt-1 text-[13px] font-semibold" style="color: var(--muted);">
              {st.l}
            </div>
          </div>
        ))
      }
    </div>

    <div class="mb-10 text-center">
      <div class="accent-bar mx-auto mb-4"></div>
      <h2 class="font-display text-[32px] font-bold" style="color: var(--navy-950);">Our values</h2>
    </div>
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {
        values.map((v) => (
          <div class="rounded-[var(--radius-md)] border border-[var(--line)] bg-white p-6">
            <span
              class="mb-4 flex h-11 w-11 items-center justify-center rounded-[3px]"
              style="background: #e6eef6; color: var(--navy-700);"
            >
              {v.icon === 'check' && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M20 6L9 17l-5-5" />
                </svg>
              )}
              {v.icon === 'shield' && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.85" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M12 3l7 3v6c0 4-3 6.6-7 8-4-1.4-7-4-7-8V6z" />
                </svg>
              )}
              {v.icon === 'lines' && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.85" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M4 7h16M4 12h16M4 17h10" />
                </svg>
              )}
              {v.icon === 'people' && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.85" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="12" cy="8" r="4" />
                  <path d="M4 21c0-4 4-6 8-6s8 2 8 6" />
                </svg>
              )}
            </span>
            <h3 class="font-display text-[17px] font-bold" style="color: var(--navy-950);">
              {v.title}
            </h3>
            <p class="mt-2 text-[13.5px] leading-snug" style="color: var(--muted);">
              {v.desc}
            </p>
          </div>
        ))
      }
    </div>
  </div>

  <section style="background: linear-gradient(115deg,var(--navy-950),var(--navy-700));" class="py-[52px] text-center text-white">
    <div class="marketing-container">
      <h2 class="font-display text-[28px] font-bold">Work with a logistics partner built for regulated cargo</h2>
      <a
        href="/contact"
        class="mt-5 inline-flex rounded-[var(--radius-sm)] px-7 py-3 text-[15px] font-semibold text-white"
        style="background: var(--green-500);"
      >
        Contact OMG Experience
      </a>
    </div>
  </section>
</BaseLayout>
