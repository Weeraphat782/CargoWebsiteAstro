---
import CarrierBoard from '@/components/react/CarrierBoard';
import {
  getHeroBgMode,
  HERO_FALLBACK_IMAGE,
  HERO_FALLBACK_SRCSET,
  HERO_POSTER_SRC,
  HERO_VIDEO_SRC,
} from '@/lib/hero';
import type { CarrierBoardDisplayItem } from '@/types/carrier-board';

interface Props {
  carrierItems: CarrierBoardDisplayItem[];
}

const { carrierItems } = Astro.props;
const mode = getHeroBgMode();

const heroGradientVideo =
  'linear-gradient(105deg,rgba(13,44,77,.78) 0%,rgba(13,44,77,.55) 42%,rgba(13,44,77,.32) 100%)';
const heroGradientImage =
  'linear-gradient(105deg,rgba(13,44,77,.62) 0%,rgba(13,44,77,.48) 42%,rgba(13,44,77,.28) 100%)';
---

<section class="relative overflow-hidden text-white" style="background: var(--navy-950);">
  {
    mode === 'video' ? (
      <>
        <video
          class="home-hero-video absolute inset-0 h-full w-full object-cover opacity-[0.62]"
          src={HERO_VIDEO_SRC}
          autoplay
          muted
          loop
          playsinline
          preload="auto"
          poster={HERO_POSTER_SRC}
          aria-hidden="true"
        />
        <img
          class="home-hero-static absolute inset-0 hidden h-full w-full object-cover opacity-60"
          src={HERO_POSTER_SRC}
          alt=""
          decoding="async"
          fetchpriority="high"
          aria-hidden="true"
        />
        <div class="home-hero-overlay absolute inset-0" style={`background: ${heroGradientVideo}`} />
      </>
    ) : (
      <>
        <img
          src={HERO_FALLBACK_IMAGE}
          srcset={HERO_FALLBACK_SRCSET}
          sizes="100vw"
          alt=""
          class="absolute inset-0 h-full w-full object-cover opacity-60"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          aria-hidden="true"
        />
        <div class="absolute inset-0" style={`background: ${heroGradientImage}`} />
      </>
    )
  }

  <div class="marketing-container relative grid items-center gap-12 py-16 lg:grid-cols-[1.05fr_0.95fr] lg:py-[72px]">
    <div>
      <span
        class="mb-5 inline-block rounded-[var(--radius-sm)] border px-3 py-1.5 text-[11.5px] font-bold uppercase tracking-[0.09em]"
        style="border-color: rgba(111,190,68,.45); color: #aedb93;"
      >
        GDP Certified · Pharma-Grade Logistics
      </span>
      <h1 class="font-display text-[clamp(38px,5vw,60px)] font-extrabold leading-[1.02] tracking-tight">
        Specialized Air Freight
        <br />
        &amp; Global Logistics
      </h1>
      <p class="mt-5 max-w-[520px] text-lg leading-relaxed" style="color: var(--hero-muted);">
        End-to-end logistics for time-sensitive and temperature-controlled cargo. From air freight and customs
        clearance to GDP warehousing — we deliver reliability, compliance and documented handling across your
        supply chain.
      </p>
      <div class="mt-8 flex flex-wrap gap-3.5">
        <a
          href="/contact"
          class="inline-flex items-center gap-2 rounded-[var(--radius-sm)] px-6 py-3.5 text-base font-semibold text-white"
          style="background: var(--green-500);"
        >
          Request a Quote →
        </a>
        <a
          href="/services"
          class="inline-flex items-center rounded-[var(--radius-sm)] border px-6 py-3.5 text-base font-semibold text-white"
          style="border-color: rgba(255,255,255,.4); background: rgba(255,255,255,.1);"
        >
          View Services
        </a>
      </div>
    </div>
    <CarrierBoard client:idle items={carrierItems} />
  </div>
  <div class="relative border-t border-white/10" style="background: rgba(9,26,45,.6);">
    <div class="marketing-container grid grid-cols-1 py-7 sm:grid-cols-3">
      {
        [
          { v: '7+', l: 'Countries Served' },
          { v: 'GDP', l: 'Certified Handling' },
          { v: 'AI', l: 'Document Intelligence' },
        ].map((s, i) => (
          <div class={`text-center ${i < 2 ? 'sm:border-r sm:border-white/12' : ''}`}>
            <div class="font-display text-[34px] font-extrabold" style="color: var(--green-500);">
              {s.v}
            </div>
            <div class="mt-0.5 text-[11px] font-medium uppercase tracking-[0.12em]" style="color: #9fb6cf;">
              {s.l}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

{
  mode === 'video' && (
    <style is:global>
      @media (prefers-reduced-motion: reduce) {
        .home-hero-video {
          display: none !important;
        }
        .home-hero-static {
          display: block !important;
        }
        .home-hero-overlay {
          background: linear-gradient(
            105deg,
            rgba(13, 44, 77, 0.62) 0%,
            rgba(13, 44, 77, 0.48) 42%,
            rgba(13, 44, 77, 0.28) 100%
          ) !important;
        }
      }
    </style>
  )
}
