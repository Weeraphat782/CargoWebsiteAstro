---
import { newsroomListPagePath } from '@/lib/newsroom-data';

interface Props {
  currentPage: number;
  totalPages: number;
}

const { currentPage, totalPages } = Astro.props;

const prevPage = currentPage > 1 ? currentPage - 1 : null;
const nextPage = currentPage < totalPages ? currentPage + 1 : null;
---

{
  totalPages > 1 && (
    <nav class="mt-11 flex flex-wrap items-center justify-center gap-1.5" aria-label="Newsroom pagination">
      {prevPage ? (
        <a href={newsroomListPagePath(prevPage)} class="page-btn px-3" style="color: #9aa2aa;">
          Previous
        </a>
      ) : (
        <span class="page-btn px-3 opacity-40">Previous</span>
      )}
      {Array.from({ length: totalPages }, (_, i) => i + 1).map((page) => (
        <a
          href={newsroomListPagePath(page)}
          class:list={['page-btn', page === currentPage && 'current']}
          aria-current={page === currentPage ? 'page' : undefined}
        >
          {page}
        </a>
      ))}
      {nextPage ? (
        <a
          href={newsroomListPagePath(nextPage)}
          class="page-btn border-0 px-3 font-semibold"
          style="color: var(--navy-700);"
        >
          Next
        </a>
      ) : (
        <span class="page-btn px-3 opacity-40">Next</span>
      )}
    </nav>
  )
}
