---
import { newsroomListPagePath } from '@/lib/newsroom-data';

interface Props {
  currentPage: number;
  totalPages: number;
}

const { currentPage, totalPages } = Astro.props;

const prevPage = currentPage > 1 ? currentPage - 1 : null;
const nextPage = currentPage < totalPages ? currentPage + 1 : null;
---

{
  totalPages > 1 && (
    <nav
      class="mt-12 flex flex-wrap items-center justify-center gap-2 border-t border-neutral-200 pt-8"
      aria-label="Newsroom pagination"
    >
      {prevPage ? (
        <a
          href={newsroomListPagePath(prevPage)}
          class="inline-flex min-h-[44px] items-center rounded-lg border border-neutral-200 px-4 py-2 text-sm font-medium text-neutral-700 hover:bg-neutral-50"
        >
          Previous
        </a>
      ) : (
        <span class="inline-flex min-h-[44px] cursor-not-allowed items-center rounded-lg border border-neutral-100 px-4 py-2 text-sm text-neutral-300">
          Previous
        </span>
      )}
      {Array.from({ length: totalPages }, (_, i) => i + 1).map((page) => (
        <a
          href={newsroomListPagePath(page)}
          class:list={[
            'inline-flex h-10 min-w-[2.5rem] items-center justify-center rounded-lg px-3 text-sm font-medium',
            page === currentPage
              ? 'text-white'
              : 'border border-neutral-200 text-neutral-700 hover:bg-neutral-50',
          ]}
          style={page === currentPage ? { backgroundColor: 'var(--color-primary-ref)' } : undefined}
          aria-current={page === currentPage ? 'page' : undefined}
        >
          {page}
        </a>
      ))}
      {nextPage ? (
        <a
          href={newsroomListPagePath(nextPage)}
          class="inline-flex min-h-[44px] items-center rounded-lg border border-neutral-200 px-4 py-2 text-sm font-medium text-neutral-700 hover:bg-neutral-50"
        >
          Next
        </a>
      ) : (
        <span class="inline-flex min-h-[44px] cursor-not-allowed items-center rounded-lg border border-neutral-100 px-4 py-2 text-sm text-neutral-300">
          Next
        </span>
      )}
    </nav>
  )
}
